generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Product {
  id                       Int                     @id @default(autoincrement()) @db.UnsignedInt
  sourceUrl                String                  @map("source_url") @db.VarChar(1024)
  title                    String                  @db.VarChar(255)
  price                    String?                 @db.VarChar(64)
  description              String?                 @db.Text
  sizeInfo                 String?                 @map("size_info") @db.Text
  specification            String?                 @db.Text
  brand                    String?                 @db.VarChar(255)
  status                   String                  @default("草稿") @db.VarChar(32)
  processedTitle           String?                 @map("processed_title") @db.VarChar(255)
  processedDescription     String?                 @map("processed_description") @db.Text
  processedDescriptionHtml String?                 @map("processed_description_html") @db.Text
  processedSizeInfo        String?                 @map("processed_size_info") @db.Text
  processedSpecification   String?                 @map("processed_specification") @db.Text
  aiSellingPoints          Json?                   @map("ai_selling_points")
  aiAttributes             Json?                   @map("ai_attributes")
  taobaoPayload            Json?                   @map("taobao_payload")
  aiProcessStatus          String                  @default("PROCESSING") @map("ai_process_status") @db.VarChar(32)
  aiProcessError           String?                 @map("ai_process_error") @db.Text
  aiProcessedAt            DateTime?               @map("ai_processed_at") @db.DateTime(0)
  imageProcessStatus       String                  @default("PROCESSING") @map("image_process_status") @db.VarChar(32)
  imageProcessError        String?                 @map("image_process_error") @db.Text
  imageProcessedAt         DateTime?               @map("image_processed_at") @db.DateTime(0)
  imageCenterStatus        String                  @default("IDLE") @map("image_center_status") @db.VarChar(32)
  imageCenterError         String?                 @map("image_center_error") @db.Text
  imageCenterProcessedAt   DateTime?               @map("image_center_processed_at") @db.DateTime(0)
  publishStatus            String                  @default("DRAFT") @map("publish_status") @db.VarChar(32)
  publishError             String?                 @map("publish_error") @db.Text
  publishCheckpoint        String?                 @map("publish_checkpoint") @db.VarChar(64)
  publishResult            Json?                   @map("publish_result")
  taobaoProductId          String?                 @map("taobao_product_id") @db.VarChar(128)
  publishLogPath           String?                 @map("publish_log_path") @db.VarChar(1024)
  publishScreenshotPath    String?                 @map("publish_screenshot_path") @db.VarChar(1024)
  publishedAt              DateTime?               @map("published_at") @db.DateTime(0)
  createdAt                DateTime                @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt                DateTime                @updatedAt @map("updated_at") @db.DateTime(0)
  images                   ProductImage[]
  generatedImages          ProductGeneratedImage[]
  skus                     ProductSku[]
  processingTask           ProductProcessingTask?
  imageProcessingTasks     ProductImageProcessingTask[]
  imageGenerationTasks     ProductImageGenerationTask[]
  publishTask              ProductPublishTask?
  importTasks              ProductImportTask[]

  @@map("products")
}

model ProductProcessingTask {
  id           Int       @id @default(autoincrement()) @db.UnsignedInt
  productId    Int       @unique @map("product_id") @db.UnsignedInt
  status       String    @default("PROCESSING") @db.VarChar(32)
  attemptCount Int       @default(0) @map("attempt_count")
  maxAttempts  Int       @default(3) @map("max_attempts")
  availableAt  DateTime  @default(now()) @map("available_at") @db.DateTime(0)
  lockedAt     DateTime? @map("locked_at") @db.DateTime(0)
  lastError    String?   @map("last_error") @db.Text
  finishedAt   DateTime? @map("finished_at") @db.DateTime(0)
  createdAt    DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.DateTime(0)
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([status, availableAt])
  @@map("product_processing_tasks")
}

model ProductImage {
  id                  Int                      @id @default(autoincrement()) @db.UnsignedInt
  productId           Int                      @map("product_id") @db.UnsignedInt
  imageUrl            String                   @map("image_url") @db.Text
  originalImageUrl    String?                  @map("original_image_url") @db.Text
  taobaoMainImageUrl  String?                  @map("taobao_main_image_url") @db.Text
  taobaoDetailImageUrl String?                 @map("taobao_detail_image_url") @db.Text
  mimeType            String?                  @map("mime_type") @db.VarChar(128)
  width               Int?                     @db.UnsignedInt
  height              Int?                     @db.UnsignedInt
  fileSize            Int?                     @map("file_size") @db.UnsignedInt
  processStatus       String                   @default("PROCESSING") @map("process_status") @db.VarChar(32)
  processError        String?                  @map("process_error") @db.Text
  processedAt         DateTime?                @map("processed_at") @db.DateTime(0)
  isCover             Boolean                  @default(false) @map("is_cover")
  sortOrder           Int                      @default(0) @map("sort_order")
  sourceType          String                   @default("CRAWLED") @map("source_type") @db.VarChar(32)
  createdAt           DateTime                 @default(now()) @map("created_at") @db.DateTime(0)
  product             Product                  @relation(fields: [productId], references: [id], onDelete: Cascade)
  processingTask      ProductImageProcessingTask?
  generatedImages     ProductGeneratedImage[]
  imageGenerationTasks ProductImageGenerationTask[]

  @@index([productId])
  @@index([processStatus])
  @@map("product_images")
}

model ProductImageProcessingTask {
  id           Int          @id @default(autoincrement()) @db.UnsignedInt
  imageId       Int         @unique @map("image_id") @db.UnsignedInt
  productId     Int         @map("product_id") @db.UnsignedInt
  status        String      @default("PROCESSING") @db.VarChar(32)
  attemptCount  Int         @default(0) @map("attempt_count")
  maxAttempts   Int         @default(3) @map("max_attempts")
  availableAt   DateTime    @default(now()) @map("available_at") @db.DateTime(0)
  lockedAt      DateTime?   @map("locked_at") @db.DateTime(0)
  lastError     String?     @map("last_error") @db.Text
  finishedAt    DateTime?   @map("finished_at") @db.DateTime(0)
  createdAt     DateTime    @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.DateTime(0)
  image         ProductImage @relation(fields: [imageId], references: [id], onDelete: Cascade)
  product       Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([status, availableAt])
  @@map("product_image_processing_tasks")
}

model ProductGeneratedImage {
  id           Int          @id @default(autoincrement()) @db.UnsignedInt
  productId     Int         @map("product_id") @db.UnsignedInt
  sourceImageId Int?        @map("source_image_id") @db.UnsignedInt
  category      String      @db.VarChar(32)
  slotIndex     Int?        @map("slot_index")
  sourceType    String      @default("PRODUCT_IMAGE") @map("source_type") @db.VarChar(32)
  sourceUrl     String?     @map("source_url") @db.Text
  sourceSkuCode String?     @map("source_sku_code") @db.VarChar(128)
  storageKey    String      @map("storage_key") @db.VarChar(1024)
  imageUrl      String      @map("image_url") @db.Text
  mimeType      String?     @map("mime_type") @db.VarChar(128)
  width         Int?        @db.UnsignedInt
  height        Int?        @db.UnsignedInt
  fileSize      Int?        @map("file_size") @db.UnsignedInt
  isDefault     Boolean     @default(false) @map("is_default")
  sortOrder     Int         @default(0) @map("sort_order")
  status        String      @default("SUCCESS") @db.VarChar(32)
  error         String?     @db.Text
  metadata      Json?
  createdAt     DateTime    @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.DateTime(0)
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  sourceImage   ProductImage? @relation(fields: [sourceImageId], references: [id], onDelete: SetNull)

  @@index([productId, category, sortOrder])
  @@index([sourceImageId])
  @@map("product_generated_images")
}

model ProductImageGenerationTask {
  id            Int       @id @default(autoincrement()) @db.UnsignedInt
  productId      Int      @map("product_id") @db.UnsignedInt
  taskType       String   @map("task_type") @db.VarChar(32)
  category       String   @db.VarChar(32)
  status         String   @default("QUEUED") @db.VarChar(32)
  progress       Int      @default(0)
  sourceImageId  Int?     @map("source_image_id") @db.UnsignedInt
  sourceSkuCode  String?  @map("source_sku_code") @db.VarChar(128)
  sourceUrl      String?  @map("source_url") @db.Text
  targetSlot     Int?     @map("target_slot")
  queueJobId     String?  @map("queue_job_id") @db.VarChar(128)
  attemptCount   Int      @default(0) @map("attempt_count")
  maxAttempts    Int      @default(3) @map("max_attempts")
  payload        Json?
  result         Json?
  lastError      String?  @map("last_error") @db.Text
  finishedAt     DateTime? @map("finished_at") @db.DateTime(0)
  createdAt      DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.DateTime(0)
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sourceImage    ProductImage? @relation(fields: [sourceImageId], references: [id], onDelete: SetNull)

  @@index([productId, status])
  @@index([category, status])
  @@map("product_image_generation_tasks")
}

model ProductSku {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  productId Int      @map("product_id") @db.UnsignedInt
  skuCode   String   @map("sku_code") @db.VarChar(128)
  name      String?  @map("name") @db.VarChar(255)
  color     String?  @db.VarChar(128)
  size      String?  @db.VarChar(128)
  price     String?  @db.VarChar(64)
  stock     Int      @default(999) @db.UnsignedInt
  imageUrl  String?  @map("image_url") @db.VarChar(1024)
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([skuCode])
  @@map("product_skus")
}

model ProductPublishTask {
  id                  Int       @id @default(autoincrement()) @db.UnsignedInt
  productId           Int       @unique @map("product_id") @db.UnsignedInt
  status              String    @default("QUEUED") @db.VarChar(32)
  checkpoint          String?   @db.VarChar(64)
  attemptCount        Int       @default(0) @map("attempt_count")
  maxAttempts         Int       @default(3) @map("max_attempts")
  availableAt         DateTime  @default(now()) @map("available_at") @db.DateTime(0)
  lockedAt            DateTime? @map("locked_at") @db.DateTime(0)
  lastError           String?   @map("last_error") @db.Text
  latestLogPath       String?   @map("latest_log_path") @db.VarChar(1024)
  latestScreenshotPath String?  @map("latest_screenshot_path") @db.VarChar(1024)
  publishResult       Json?     @map("publish_result")
  finishedAt          DateTime? @map("finished_at") @db.DateTime(0)
  createdAt           DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.DateTime(0)
  product             Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([status, availableAt])
  @@map("product_publish_tasks")
}

model AppSetting {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  key       String   @unique @db.VarChar(128)
  value     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  @@map("app_settings")
}

model ProductImportTask {
  id          Int       @id @default(autoincrement()) @db.UnsignedInt
  sourceUrl   String    @map("source_url") @db.VarChar(1024)
  status      String    @default("PENDING") @db.VarChar(32)
  productId   Int?      @map("product_id") @db.UnsignedInt
  error       String?   @db.Text
  finishedAt  DateTime? @map("finished_at") @db.DateTime(0)
  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.DateTime(0)

  product     Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@map("product_import_tasks")
}

model StockMonitorProduct {
  id            Int              @id @default(autoincrement()) @db.UnsignedInt
  sourceUrl     String           @map("source_url") @db.VarChar(1024)
  title         String           @db.VarChar(255)
  brand         String?          @db.VarChar(255)
  price         String?          @db.VarChar(64)
  imageUrl      String?          @map("image_url") @db.VarChar(1024)
  isPinned      Boolean          @default(false) @map("is_pinned")
  lastCheckedAt DateTime?        @map("last_checked_at") @db.DateTime(0)
  checkStatus   String           @default("PENDING") @map("check_status") @db.VarChar(32)
  checkError    String?          @map("check_error") @db.Text
  createdAt     DateTime         @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt     DateTime         @updatedAt @map("updated_at") @db.DateTime(0)
  skus          StockMonitorSku[]

  @@index([checkStatus, createdAt])
  @@map("stock_monitor_products")
}

model StockMonitorSku {
  id             Int       @id @default(autoincrement()) @db.UnsignedInt
  productId      Int       @map("product_id") @db.UnsignedInt
  skuCode        String    @map("sku_code") @db.VarChar(128)
  color          String?   @db.VarChar(128)
  colorCode      String?   @map("color_code") @db.VarChar(64)
  size           String?   @db.VarChar(128)
  stockStatus    String    @map("stock_status") @db.VarChar(32)
  restockDate    String?   @map("restock_date") @db.VarChar(64)
  price          String?   @db.VarChar(64)
  lastCheckedAt  DateTime? @map("last_checked_at") @db.DateTime(0)
  createdAt      DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.DateTime(0)
  product        StockMonitorProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([skuCode])
  @@map("stock_monitor_skus")
}
